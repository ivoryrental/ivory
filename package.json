{
  "name": "temp_app",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "dev": "npm run prisma:generate:local && next dev --webpack -H 0.0.0.0",
    "build": "next build",
    "build:vercel": "npm run prisma:generate:postgres && npm run db:deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate:local": "prisma generate --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "prisma:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.28.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/nodemailer": "^7.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^5.10.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
