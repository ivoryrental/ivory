# Any value marked "REQUIRED" below is a production deployment blocker.
# Local development (SQLite)
DATABASE_URL="file:./dev.db"
# REQUIRED (production): PostgreSQL URL from Neon/Vercel.
# Production on Vercel/Neon (replace DATABASE_URL in Vercel env variables):
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true&connection_limit=1"

# Authentication
# Generate a strong secret: openssl rand -base64 32
AUTH_SECRET="your_32_char_min_random_secret_here_generate_with_openssl"

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use an App Password, NOT your regular password!
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=your_email@gmail.com
ADMIN_EMAIL=your_email@gmail.com

# Public Site URL (for metadata, sitemap, redirects)
NEXT_PUBLIC_SITE_URL=https://ivory.ge

# Optional: Legacy admin credentials (fallback only)
# ADMIN_USER=admin
# ADMIN_PASSWORD=change_me_in_production

# REQUIRED (production): Cron Job Secret (for cleanup endpoint auth)
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# REQUIRED (production): Distributed Rate Limiting credentials
# Create a free Redis database at https://upstash.com and copy REST credentials
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Optional: extra trusted origins for admin/server actions (comma-separated)
# ALLOWED_ORIGINS=https://ivory.ge,https://www.ivory.ge
